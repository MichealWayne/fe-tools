{
  "name": "vite-vue3",
  "private": true,
  "version": "0.1.0",
  "author": "wayne",
  "task": "test",
  "scripts": {
    "dev": "vite",
    "start": "npm run dev",
    "build": "vue-tsc --noEmit && vite build --mode staging",
    "build:prod": "vue-tsc --noEmit && vite build --mode production && node build/index",
    "preview": "vite preview",
    "lint": "eslint src --ext .vue,.ts,.js",
    "lint:fix": "eslint src --ext .vue,.ts,.js --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,js,less,css}\"",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "vue": "^3.2.25"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-vue": "^4.1.0",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.32.0",
    "jsdom": "^24.1.0",
    "less": "^4.2.0",
    "less-loader": "^11.1.4",
    "postcss-pxtorem": "^6.0.0",
    "prettier": "^3.8.3",
    "typescript": "^5.0.2",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^4.3.2",
    "vitest": "^1.6.1",
    "vue-tsc": "^1.4.2"
  }
}
