{
  "name": "fastify-template",
  "version": "1.0.0",
  "port": "3000",
  "author": "Wayne",
  "description": "Fastify node.js server template with TypeScript",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "tsc && node dist/",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "rm -rf dist/* && tsc",
    "build:prod": "tsc && rm -rf node_modules && npm install --production",
    "install:prod": "npm install --production",
    "docker:start": "npm install && node dist/",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest"
  },
  "keywords": [
    "fastify",
    "nodejs",
    "typescript"
  ],
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.2",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/error": "^4.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@sinclair/typebox": "^0.34.49",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "log4js": "^6.9.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.4.3"
  }
}
