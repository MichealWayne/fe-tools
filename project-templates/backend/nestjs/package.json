{
    "name": "nestjs-template",
    "version": "1.0.0",
    "port": "5000",
    "author": "Wayne",
    "description": "nestjs nodejs server template.",
    "main": "dist/main.js",
    "scripts": {
        "start": "tsc && node dist/main.js",
        "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
        "build": "rm -rf dist/* && tsc",
        "build:prod": "tsc && rm -rf node_modules && npm install --production",
        "install:prod": "npm install --production",
        "docker:start": "npm install && node dist/main.js",
        "lint": "eslint . --ext .ts",
        "lint:fix": "eslint . --ext .ts --fix",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write \"src/**/*.ts\"",
        "test": "jest",
        "test:watch": "jest --watch"
    },
    "keywords": [
        "nestjs",
        "nodejs"
    ],
    "license": "ISC",
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^5.59.0",
        "@typescript-eslint/parser": "^5.59.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^18.0.0",
        "eslint": "^8.39.0",
        "jest": "^30.4.2",
        "prettier": "^3.8.3",
        "ts-jest": "^29.4.11",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.6.0"
    },
    "dependencies": {
        "@nestjs/common": "^10.0.0",
        "@nestjs/core": "^10.0.0",

        "@nestjs/platform-fastify": "^10.4.20",
        "fastify": "^4.29.1",
        "log4js": "^6.9.1",
        "reflect-metadata": "^0.1.13",
        "rxjs": "^7.8.0"
    }
}
