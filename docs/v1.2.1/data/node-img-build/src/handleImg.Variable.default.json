":"toBlurImg","kind":4096,"kindString":"Call signature","flags":{},"comment":{"summary":[],"blockTags":[{"tag":"@description","content":[{"kind":"text","text":"Apply blur effect to an image using GraphicsMagick processing"}]},{"tag":"@returns","content":[{"kind":"text","text":"Modified GM stream with blur applied, or false if processing fails"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\r\n// Apply default blur effect\r\nconst { gmStream } = await getGmStream('./images', 'photo.jpg');\r\nconst blurred = toBlurImg(gmStream);\r\n\r\n```"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\r\n// Custom blur with artistic effect\r\nconst artisticBlur = toBlurImg(gmStream, {\r\n  color: 16,        // Preserve more colors\r\n  blurRadius: 15,   // Stronger blur\r\n  blurSigma: 8      // Smoother effect\r\n});\r\n\r\n```"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\r\n// Subtle blur for background images\r\nconst subtleBlur = toBlurImg(gmStream, {\r\n  color: 32,        // High color preservation\r\n  blurRadius: 3,    // Light blur\r\n  blurSigma: 1      // Minimal sigma\r\n});\r\n\r\n```"}]},{"tag":"@since","content":[{"kind":"text","text":"1.0.0"}]}]},"parameters":[{"id":1618,"name":"gmStream","kind":32768,"kindString":"Parameter","flags":{},"comment":{"summary":[{"kind":"text","text":"GraphicsMagick image stream to process"}]},"type":{"type":"reference","name":"State","qualifiedName":"m.State","package":"@types/gm"},"text":{"comment":"<p>GraphicsMagick image stream to process</p>\n"}},{"id":1619,"name":"options","kind":32768,"kindString":"Parameter","flags":{"isOptional":true},"comment":{"summary":[{"kind":"text","text":"Blur effect configuration options"}]},"type":{"type":"reference","id":1592,"name":"BlurOptions"},"defaultValue":"{}","text":{"comment":"<p>Blur effect configuration options</p>\n"}}],"type":{"type":"union","types":[{"type":"reference","name":"gmConstructor.State","qualifiedName":"m.State","package":"@types/gm"},{"type":"literal","value":false}]},"is":{"declaration":false},"location":{"query":"node-img-build/src/handleImg.Variable.default","hash":"toBlurImg.__type"},"text":{"comment":"<h5>Description:</h5><p>Apply blur effect to an image using GraphicsMagick processing</p>\n<h5>Returns:</h5><p>Modified GM stream with blur applied, or false if processing fails</p>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Apply default blur effect</span>\n<span class=\"pl-k\">const</span> { <span class=\"pl-c1\">gmStream</span> } <span class=\"pl-k\">=</span> <span class=\"pl-k\">await</span> <span class=\"pl-en\">getGmStream</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>./images<span class=\"pl-pds\">'</span></span>, <span class=\"pl-s\"><span class=\"pl-pds\">'</span>photo.jpg<span class=\"pl-pds\">'</span></span>);\n<span class=\"pl-k\">const</span> <span class=\"pl-c1\">blurred</span> <span class=\"pl-k\">=</span> <span class=\"pl-en\">toBlurImg</span>(<span class=\"pl-smi\">gmStream</span>);\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Custom blur with artistic effect</span>\n<span class=\"pl-k\">const</span> <span class=\"pl-c1\">artisticBlur</span> <span class=\"pl-k\">=</span> <span class=\"pl-en\">toBlurImg</span>(<span class=\"pl-smi\">gmStream</span>, {\n  color: <span class=\"pl-c1\">16</span>,        <span class=\"pl-c\">// Preserve more colors</span>\n  blurRadius: <span class=\"pl-c1\">15</span>,   <span class=\"pl-c\">// Stronger blur</span>\n  blurSigma: <span class=\"pl-c1\">8</span>      <span class=\"pl-c\">// Smoother effect</span>\n});\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Subtle blur for background images</span>\n<span class=\"pl-k\">const</span> <span class=\"pl-c1\">subtleBlur</span> <span class=\"pl-k\">=</span> <span class=\"pl-en\">toBlurImg</span>(<span class=\"pl-smi\">gmStream</span>, {\n  color: <span class=\"pl-c1\">32</span>,        <span class=\"pl-c\">// High color preservation</span>\n  blurRadius: <span class=\"pl-c1\">3</span>,    <span class=\"pl-c\">// Light blur</span>\n  blurSigma: <span class=\"pl-c1\">1</span>      <span class=\"pl-c\">// Minimal sigma</span>\n});\n</code></pre>\n<h5>Since:</h5><p>1.0.0</p>\n"},"sources":[{"fileName":"packages/node-img-build/src/handleImg.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/node-img-build/src/handleImg.ts","line":209,"character":0,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-img-build/src/handleImg.ts#L209"}],"parentId":1598}],"location":{"query":"node-img-build/src/handleImg.Variable.default","hash":"toBlurImg"}}},"is":{"declaration":true},"location":{"query":"node-img-build/src/handleImg.Variable.default","hash":"toBlurImg"},"text":{},"parentId":1598},{"id":1608,"name":"toWebpImg","kind":4096,"kindString":"Property","flags":{},"sources":[{"fileName":"packages/node-img-build/src/handleImg.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/node-img-build/src/handleImg.ts","line":417,"character":2,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-img-build/src/handleImg.ts#L417"}],"type":{"type":"reflection","declaration":{"id":1609,"name":"toWebpImg","kind":65536,"kindString":"Type literal","flags":{},"sources":[{"fileName":"packages/node-img-build/src/handleImg.ts","line":142,"character":16,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-img-build/src/handleImg.ts#L142"}],"signatures":[{"id":1610,"name":"toWebpImg","kind":4096,"kindString":"Call signature","flags":{},"comment":{"summary":[],"blockTags":[{"tag":"@description","content":[{"kind":"text","text":"Convert an image to WebP format with automatic filename handling for retina images"}]},{"tag":"@returns","content":[{"kind":"text","text":"Promise resolving to the full path of the generated WebP file"}]},{"tag":"@throws","co