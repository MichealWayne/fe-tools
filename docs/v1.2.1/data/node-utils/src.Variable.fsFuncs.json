');\nif (pkg.name) {\n  console.log(`Package: ${pkg.name}@${pkg.version}`);\n} else {\n  console.log('Invalid or missing package.json');\n}\n\n```"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Read user data with fallback\nconst userData = readJsonFile('./user-data.json');\nconst users = userData.users || [];\nconsole.log(`Found ${users.length} users`);\n\n```"}]},{"tag":"@see","content":[{"kind":"inline-tag","tag":"@link","text":"readFileSync","target":2117},{"kind":"text","text":" - Underlying file read function"}]}]},"parameters":[{"id":1848,"name":"filePath","kind":32768,"kindString":"Parameter","flags":{},"comment":{"summary":[{"kind":"text","text":"要读取的JSON文件路径。The JSON file path to read"}]},"type":{"type":"intrinsic","name":"string"},"text":{"comment":"<p>要读取的JSON文件路径。The JSON file path to read</p>\n"}}],"type":{"type":"intrinsic","name":"any"},"is":{"declaration":false},"location":{"query":"node-utils/src.Variable.fsFuncs","hash":"readJsonFile.__type"},"text":{"comment":"<h5>Function:</h5><p>readJsonFile</p>\n<h5>Description:</h5><p>读取并解析JSON文件，对无效JSON进行错误处理。Reads and parses a JSON file with comprehensive error handling for invalid JSON and missing files.</p>\n<h5>Returns:</h5><p>解析的JSON对象，如果文件不存在或解析失败则返回空对象。Parsed JSON object, or empty object if file doesn&#39;t exist or parsing fails</p>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Read configuration JSON</span>\n<span class=\"pl-k\">const</span> <span class=\"pl-c1\">config</span> <span class=\"pl-k\">=</span> <span class=\"pl-en\">readJsonFile</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>./config.json<span class=\"pl-pds\">'</span></span>);\n<span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>Server port:<span class=\"pl-pds\">'</span></span>, <span class=\"pl-smi\">config</span>.<span class=\"pl-c1\">port</span> <span class=\"pl-k\">||</span> <span class=\"pl-c1\">3000</span>);\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Read package.json safely</span>\n<span class=\"pl-k\">const</span> <span class=\"pl-c1\">pkg</span> <span class=\"pl-k\">=</span> <span class=\"pl-en\">readJsonFile</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>./package.json<span class=\"pl-pds\">'</span></span>);\n<span class=\"pl-k\">if</span> (<span class=\"pl-smi\">pkg</span>.<span class=\"pl-c1\">name</span>) {\n  <span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">`</span>Package: ${<span class=\"pl-smi\">pkg</span>.<span class=\"pl-c1\">name</span>}@${<span class=\"pl-smi\">pkg</span>.<span class=\"pl-c1\">version</span>}<span class=\"pl-pds\">`</span></span>);\n} <span class=\"pl-k\">else</span> {\n  <span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>Invalid or missing package.json<span class=\"pl-pds\">'</span></span>);\n}\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Read user data with fallback</span>\n<span class=\"pl-k\">const</span> <span class=\"pl-c1\">userData</span> <span class=\"pl-k\">=</span> <span class=\"pl-en\">readJsonFile</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>./user-data.json<span class=\"pl-pds\">'</span></span>);\n<span class=\"pl-k\">const</span> <span class=\"pl-c1\">users</span> <span class=\"pl-k\">=</span> <span class=\"pl-smi\">userData</span>.<span class=\"pl-smi\">users</span> <span class=\"pl-k\">||</span> [];\n<span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">`</span>Found ${<span class=\"pl-smi\">users</span>.<span class=\"pl-c1\">length</span>} users<span class=\"pl-pds\">`</span></span>);\n</code></pre>\n<h5>See:</h5><p><a href=\"2117\">readFileSync</a> - Underlying file read function</p>\n"},"sources":[{"file