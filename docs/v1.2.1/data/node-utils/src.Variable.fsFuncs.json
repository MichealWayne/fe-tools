s console output when folder already exists</p>\n"}}],"type":{"type":"intrinsic","name":"void"},"is":{"declaration":false},"location":{"query":"node-utils/src.Variable.fsFuncs","hash":"setFolderSync.__type"},"text":{"comment":"<h5>Function:</h5><p>setFolderSync</p>\n<h5>Description:</h5><p>同步确保文件夹存在，必要时创建它。Synchronously ensures a folder exists, creating it if necessary with optional console output control.</p>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Create folder with console feedback</span>\n<span class=\"pl-en\">setFolderSync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>./output<span class=\"pl-pds\">'</span></span>);\n<span class=\"pl-c\">// Logs: \"(./output folder existed.)\" if folder exists</span>\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Create folder silently</span>\n<span class=\"pl-en\">setFolderSync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>./temp<span class=\"pl-pds\">'</span></span>, <span class=\"pl-c1\">true</span>);\n<span class=\"pl-c\">// No console output regardless of folder state</span>\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Ensure upload directory exists before file operations</span>\n<span class=\"pl-en\">setFolderSync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>./uploads<span class=\"pl-pds\">'</span></span>);\n<span class=\"pl-c\">// Now safe to write files to ./uploads/</span>\n</code></pre>\n<h5>See:</h5><p><a href=\"2091\">mkdirsSync</a> - For more control over directory creation</p>\n"},"sources":[{"fileName":"packages/node-utils/src/fs/fsFuncs.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/node-utils/src/fs/fsFuncs.ts","line":187,"character":0,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/fs/fsFuncs.ts#L187"}],"parentId":1804}],"location":{"query":"node-utils/src.Variable.fsFuncs","hash":"setFolderSync"}}},"is":{"declaration":true},"location":{"query":"node-utils/src.Variable.fsFuncs","hash":"setFolderSync"},"text":{},"parentId":1804},{"id":1806,"name":"travelFolderSync","kind":4096,"kindString":"Property","flags":{},"sources":[{"fileName":"packages/node-utils/src/fs/fsFuncs.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/node-utils/src/fs/fsFuncs.ts","line":413,"character":2,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/fs/fsFuncs.ts#L413"}],"type":{"type":"reflection","declaration":{"id":1807,"name":"travelFolderSync","kind":65536,"kindString":"Type literal","flags":{},"sources":[{"fileName":"packages/node-utils/src/fs/fsFuncs.ts","line":45,"character":16,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/fs/fsFuncs.ts#L45"}],"signatures":[{"id":1808,"name":"travelFolderSync","kind":4096,"kindString":"Call signature","flags":{},"comment":{"summary":[],"blockTags":[{"tag":"@function","content":[{"kind":"text","text":"travelFolderSync"}]},{"tag":"@description","content":[{"kind":"text","text":"递归遍历目录并对文件和文件夹执行回调函数。Recursively traverses a directory and executes callbacks for files and folders with comprehensive error handling."}]},{"tag":"@throws","content":[{"kind":"text","text":"如果目录不存在则记录错误但不抛出。Logs error if directory doesn't exist but doesn't throw"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Basic directory traversal\ntravelFolderSync('./src',\n  (filePath) => console.log('File:', filePath),\n  (folderPath) => console.log('Folder:', folderPath)\n);\n\n```"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Count files and folders\nlet fileCount = 0, folderCount = 0;\ntravelFolderSync('./project',\n  () => fileCount++,\n  () => folderCount++\n);\nconsole.log(`Found ${fileCount} files and ${folderCount} folders`);\n```"}]}]},"parameters":[{"id":1809,"name":"dirPath","kind":32768,"kindString":"Parameter","flags":{},"comment":{"summary":[{"kind":"text","text":"要遍历的目录路径。The directory path to traverse"}]},"type":{"type":"intrinsic","name":"string"},"text":{"comment":"<p>要遍历的目录路径。The directory path to traverse</p>\n"}},{"id":1810,"name":"fileCallback","kind":32768,"kindString":"Parameter","flags":{},"comment":{"summary":[{"kind":"text","text":"对每个找到的文件执行的回调函数。Callback function executed for each file found"}]},"type":{"type":"reflection","declaration":{"id":1811,"name":"__type","kind":65536,"kindString":"Type literal","flags":{},"sources":[{"fileName":"packages/node-utils/src/fs/fsFuncs.ts","line":47,"character":16,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/fs/fsFuncs.ts#L47"}],"signatures":[{"id":1812,"name":"__type","kind":4096,"kindString":"Call signature","flags":{},"parameters":[{"id":1813,"name":"pathName","kind":32768,"kindString":"Parameter","flags":{"isOptional":true},"type":{"type":"intrinsic","name":"string"}}],"type":{"type":"intrinsic","name":"void"}}]}},"text":{"comment":"<p>对每个找到的文件执行的回调函数。Callback function executed for each file found</p>\n"}},{"id":1814,"name":"folderCallback","kind":32768,"kindString":"Parameter","flags":{},"comment":{"summary":[{"kind":"text","text":"对每个找到的文件夹执行的回调函数。Callback function executed for each folder found"}]},"type":{"type":"reflection","declaration":{"id":1815,"name":"__type","kind":65536,"kindString":"Type literal","flags":{},"sources":[{"fileName":"packages/node-utils/src/fs/fsFuncs.ts","line":48,"character":18,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/fs/fsFuncs.ts#L48"}],"signatures":[{"id":1816,"name":"__type","kind":4096,"kindString":"Call signature","flags":{},"parameters":[{"id":1817,"name":"pathName","kind":32768,"kindString":"Parameter","flags":{"isOptional":true},"type":{"type":"intrinsic","name":"string"}}],"type":{"type":"intrinsic","name":"void"}}]}},"text":{"comment":"<p>对每个找到的文件夹执行的回调函数。Callback function executed for each folder found</p>\n"}}],"type":{"type":"intrinsic","name":"void"},"is":{"declaration":false},"location":{"query":"node-utils/src.Variable.fsFuncs","hash":"travelFolderSync.__type"},"text":{"comment":"<h5>Function:</h5><p>travelFolderSync</p>\n<h5>Description:</h5><p>递归遍历目录并对文件和文件夹执行回调函数。Recursively traverses a directory and executes callbacks for files and folders with comprehensive error handling.</p>\n<h5>Throws:</h5><p>如果目录不存在则记录错误但不抛出。Logs error if directory doesn&#39;t exist but doesn&#39;t throw</p>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Basic directory traversal</span>\n<span class=\"pl-en\">travelFolderSync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>./src<span class=\"pl-pds\">'</span></span>,\n  (<span class=\"pl-v\">filePath</span>) <span class=\"pl-k\">=></span> <span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>File:<span class=\"pl-pds\">'</span></span>, <span class=\"pl-smi\">filePath</span>),\n  (<span class=\"pl-v\">folderPath</span>) <span class=\"pl-k\">=></span> <span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>Folder:<span class=\"pl-pds\">'</span></span>, <span class=\"pl-smi\">folderPath</span>)\n);\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Count files and folders</span>\n<span class=\"pl-k\">let</span> <span class=\"pl-smi\">fileCount</span> <span class=\"pl-k\">=</span> <span class=\"pl-c1\">0</span>, <span class=\"pl-smi\">folderCount</span> <span class=\"pl-k\">=</span> <span class=\"pl-c1\">0</span>;\n<span class=\"pl-en\">travelFolderSync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>./project<span class=\"pl-pds\">'</span></span>,\n  () <span class=\"pl-k\">=></span> <span class=\"pl-smi\">fileCount</span><span class=\"pl-k\">++</span>,\n  () <span class=\"pl-k\">=></span> <span class=\"pl-smi\">folderCount</span><span class=\"pl-k\">++</span>\n);\n<span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">`</span>Found ${<span class=\"pl-smi\">fileCount</span>} files and ${<span class=\"pl-smi\">folderCount</span>} folders<span class=\"pl-pds\">`</span></span>);\n</code></pre>\n"},"sources":[{"fileName":"packages/node-utils/src/fs/fsFuncs.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/node-utils/src/fs/fsFuncs.ts","line":45,"character":0,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/fs/fsFuncs.ts#L45"}],"parentId":1804}],"location":{"query":"node-utils/src.Variable.fsFuncs","hash":"travelFolderSync"}}},"is":{"declaration":true},"location":{"query":"node-utils/src.Variable.fsFuncs","hash":"travelFolderSync"},"text":{},"parentId":1804},{"id":1835,"name":"writeFile","kind":4096,"kindString":"Property","flags":{},"sources":[{"fileName":"packages/node-utils/src/fs/fsFuncs.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/node-utils/src/fs/fsFuncs.ts","line":418,"character":2,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/fs/fsFuncs.ts#L418"}],"type":{"type":"reflection","declaration":{"id":1836,"name":"writeFile","kind":65536,"kindString":"Type literal","flags":{},"sources":[{"fileName":"packages/node-utils/src/fs/fsFuncs.ts","line":278,"character":22,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/fs/fsFuncs.ts#L278"}],"signatures":[{"id":1837,"name":"writeFile","kind":4096,"kindString":"Call signature","flags":{},"comment":{"summary":[],"blockTags":[{"tag":"@function","content":[{"kind":"text","text":"writeFile"}]},{"tag":"@description","content":[{"kind":"text","text":"异步写入数据到文件，根据需要创建目录。Asynchronously writes data to a file, creating directories as needed with automatic directory structure creation."}]},{"tag":"@returns","content":[{"kind":"text","text":"成功写入时解析为true的Promise。Promise that resolves to true on successful write"}]},{"tag":"@throws","content":[{"kind":"text","text":"如果写入操作失败则拒绝。Rejects if write operation fails"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Write a new file\nawait writeFile('./output.txt', 'Hello World');\nconsole.log('File written successfully');\n\n```"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Append to existing file\nawait writeFile('./log.txt', 'New log entry\\n', false);\n\n```"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Write with error handling\ntry {\n  await writeFile('./config/settings.json', JSON.stringify(config));\n  console.log('Configuration saved');\n} catch (error) {\n  console.error('Failed to save configuration:', error);\n}\n```"}]}]},"parameters":[{"id":1838,"name":"filePath","kind":32768,"kindString":"Parameter","flags":{},"comment":{"summary":[{"kind":"text","text":"要写入的文件路径。The file path to write to"}]},"type":{"type":"intrinsic","name":"string"},"text":{"comment":"<p>要写入的文件路径。The file path to write to</p>\n"}},{"id":1839,"name":"fileData","kind":32768,"kindString":"Parameter","flags":{},"comment":{"summary":[{"kind":"text","text":"要写入文件的内容。The content to write to the file"}]},"type":{"type":"intrinsic","name":"string"},"text":{"comment":"<p>要写入文件的内容。The content to write to the file</p>\n"}},{"id":1840,"name":"replace","kind":32768,"kindString":"Parameter","flags":{"isOptional":true},"comment":{"summary":[{"kind":"text","text":"如果为true，覆盖现有文件；如果为false，追加到现有文件。If true, overwrites existing file; if false, appends to existing file"}]},"type":{"type":"intrinsic","name":"boolean"},"defaultValue":"true","text":{"comment":"<p>如果为true，覆盖现有文件；如果为false，追加到现有文件。If true, overwrites existing file; if false, appends to existing file</p>\n"}}],"type":{"type":"reference","typeArguments":[{"type":"intrinsic","name":"boolean"}],"name":"Promise","qualifiedName":"Promise","package":"typescript"},"is":{"declaration":false},"location":{"query":"node-utils/src.Variable.fsFuncs","hash":"writeFile.__type"},"text":{"comment":"<h5>Function:</h5><p>writeFile</p>\n<h5>Description:</h5><p>异步写入数据到文件，根据需要创建目录。Asynchronously writes data to a file, creating directories as needed with automatic directory structure creation.</p>\n<h5>Returns:</h5><p>成功写入时解析为true的Promise。Promise that resolves to true on successful write</p>\n<h5>Throws:</h5><p>如果写入操作失败则拒绝。Rejects if write operation fails</p>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Write a new file</span>\n<span class=\"pl-k\">await</span> <span class=\"pl-en\">writeFile</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>./output.txt<span class=\"pl-pds\">'</span></span>, <span class=\"pl-s\"><span class=\"pl-pds\">'</span>Hello World<span class=\"pl-pds\">'</span></span>);\n<span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>File written successfully<span class=\"pl-pds\">'</span></span>);\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Append to existing file</span>\n<span class=\"pl-k\">await</span> <span class=\"pl-en\">writeFile</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>./log.txt<span class=\"pl-pds\">'</span></span>, <span class=\"pl-s\"><span class=\"pl-pds\">'</span>New log entry<span class=\"pl-cce\">\\n</span><span class=\"pl-pds\">'</span></span>, <span class=\"pl-c1\">false</span>);\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Write with error handling</span>\n<span class=\"pl-k\">try</span> {\n  <span class=\"pl-k\">await</span> <span class=\"pl-en\">writeFile</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>./config/settings.json<span class=\"pl-pds\">'</span></span>, <span class=\"pl-c1\">JSON</span>.<span class=\"pl-c1\">stringify</span>(<span class=\"pl-smi\">config</span>));\n  <span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>Configuration saved<span class=\"pl-pds\">'</span></span>);\n} <span class=\"pl-k\">catch</span> (<span class=\"pl-smi\">error</span>) {\n  <span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">error</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>Failed to save configuration:<span class=\"pl-pds\">'</span></span>, <span class=\"pl-smi\">error</span>);\n}\n</code></pre>\n"},"sources":[{"fileName":"packages/node-utils/src/fs/fsFuncs.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/node-utils/src/fs/fsFuncs.ts","line":278,"character":0,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/fs/fsFuncs.ts#L278"}],"parentId":1804}],"location":{"query":"node-utils/src.Variable.fsFuncs","hash":"writeFile"}}},"is":{"declaration":true},"location":{"query":"node-utils/src.Variable.fsFuncs","hash":"writeFile"},"text":{},"parentId":1804}],"groups":[{"title":"Methods","children":[1818,1827,1841,1845,1831,1822,1806,1835]}],"sources":[{"fileName":"packages/node-utils/src/fs/fsFuncs.ts","line":412,"character":15,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/fs/fsFuncs.ts#L412"}],"location":{"query":"node-utils/src.Variable.fsFuncs","hash":""}}},"is":{"declaration":true},"location":{"query":"node-utils/src.Variable.fsFuncs","hash":""},"text":{},"parentId":965}
