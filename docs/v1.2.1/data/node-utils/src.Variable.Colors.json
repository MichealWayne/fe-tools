e-tools/blob/3274750/utils/packages/node-utils/src/logging/colors.ts#L77"}],"type":{"type":"reflection","declaration":{"id":2017,"name":"get","kind":65536,"kindString":"Type literal","flags":{},"sources":[{"fileName":"packages/node-utils/src/logging/colors.ts","line":73,"character":12,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/logging/colors.ts#L73"}],"signatures":[{"id":2018,"name":"get","kind":4096,"kindString":"Call signature","flags":{},"comment":{"summary":[],"blockTags":[{"tag":"@function","content":[{"kind":"text","text":"get"}]},{"tag":"@description","content":[{"kind":"text","text":"获取带自动重置格式的终端颜色代码。Gets a terminal color code with automatic reset formatting for consistent console output styling."}]},{"tag":"@returns","content":[{"kind":"text","text":"带重置代码的格式化颜色字符串。Formatted color string with reset code for use with console.log"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Basic color usage\nconsole.log(get('FgRed'), 'This text is red');\nconsole.log(get('BgYellow'), 'This has yellow background');\n\n```"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Multiple formatting\nconsole.log(get('Bright') + get('FgGreen'), 'Bright green text');\n\n```"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Error logging with red color\nconsole.log(get('FgRed'), 'Error: Connection failed');\n\n```"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Success message with green background\nconsole.log(get('BgGreen'), 'Success: Operation completed');\n\n```"}]},{"tag":"@see","content":[{"kind":"text","text":"COLORS_MAP - Available color constants"}]}]},"parameters":[{"id":2019,"name":"type","kind":32768,"kindString":"Parameter","flags":{},"comment":{"summary":[{"kind":"text","text":"COLORS_MAP中的颜色类型。Color type from COLORS_MAP (e.g., 'FgRed', 'BgBlue', 'Bright')"}]},"type":{"type":"intrinsic","name":"string"},"text":{"comment":"<p>COLORS_MAP中的颜色类型。Color type from COLORS_MAP (e.g., &#39;FgRed&#39;, &#39;BgBlue&#39;, &#39;Bright&#39;)</p>\n"}}],"type":{"type":"intrinsic","name":"string"},"is":{"declaration":false},"location":{"query":"node-utils/src.Variable.Colors","hash":"get.__type"},"text":{"comment":"<h5>Function:</h5><p>get</p>\n<h5>Description:</h5><p>获取带自动重置格式的终端颜色代码。Gets a terminal color code with automatic reset formatting for consistent console output styling.</p>\n<h5>Returns:</h5><p>带重置代码的格式化颜色字符串。Formatted color string with reset code for use with console.log</p>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Basic color usage</span>\n<span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-en\">get</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>FgRed<span class=\"pl-pds\">'</span></span>), <span class=\"pl-s\"><span class=\"pl-pds\">'</span>This text is red<span class=\"pl-pds\">'</span></span>);\n<span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-en\">get</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>BgYellow<span class=\"pl-pds\">'</span></span>), <span class=\"pl-s\"><span class=\"pl-pds\">'</span>This has yellow background<span class=\"pl-pds\">'</span></span>);\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Multiple formatting</span>\n<span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-en\">get</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>Bright<span class=\"pl-pds\">'</span></span>) <span class=\"pl-k\">+</span> <span class=\"pl-en\">get</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>FgGreen<span class=\"pl-pds\">'</span></span>), <span class=\"pl-s\"><span class=\"pl-pds\">'</span>Bright green text<span class=\"pl-pds\">'</span></span>);\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Error logging with red color</span>\n<span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-en\">get</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>FgRed<span class=\"pl-pds\">'</span></span>), <span class=\"pl-s\"><span class=\"pl-pds\">'</span>Error: Connection failed<span class=\"pl-pds\">'</span></span>);\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Success message with green background</span>\n<span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-en\">get</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>BgGreen<span class=\"pl-pds\">'</span></span>), <span class=\"pl-s\"><span class=\"pl-pds\">'</span>Success: Operation completed<span class=\"pl-pds\">'</span></span>);\n</code></pre>\n<h5>See:</h5><p>COLORS_MAP - Available color constants</p>\n"},"sources":[{"fileName":"packages/node-utils/src/logging/colors.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/node-utils/src/logging/colors.ts","line":73,"character":12,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/logging/colors.ts#L73"}],"parentId":1988}],"location":{"query":"node-utils/src.Variable.Colors","hash":"get"}}},"is":{"declaration":true},"location":{"query":"node-utils/src.Variable.Colors","hash":"get"},"text":{},"parentId":1988}],"groups":[{"title":"Properties","children":[1990]},{"title":"Methods","children":[2016]}],"sources":[{"fileName":"packages/node-utils/src/logging/colors.ts","line":75,"character":15,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/logging/colors.ts#L75"}],"location":{"query":"node-utils/src.Variable.Colors","hash":""}}},"is":{"declaration":true},"location":{"query":"node-utils/src.Variable.Colors","hash":""},"text":{},"parentId":965}
