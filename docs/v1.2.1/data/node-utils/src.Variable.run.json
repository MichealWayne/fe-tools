<span class=\"pl-en\">parseArgs</span>();\n<span class=\"pl-k\">if</span> (<span class=\"pl-k\">!</span><span class=\"pl-smi\">args</span>.<span class=\"pl-smi\">required</span>) {\n  <span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">error</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>Missing required argument: --required<span class=\"pl-pds\">'</span></span>);\n  <span class=\"pl-en\">exit</span>();\n}\n</code></pre>\n<h5>Since:</h5><p>1.0.0</p>\n<h5>See:</h5><p><a href=\"2142\">runPromise</a> - Promise wrapper that calls exit on error</p>\n"},"sources":[{"fileName":"packages/node-utils/src/process/run.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/node-utils/src/process/run.ts","line":362,"character":0,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/process/run.ts#L362"}],"parentId":1849}],"location":{"query":"node-utils/src.Variable.run","hash":"exit"}}},"is":{"declaration":true},"location":{"query":"node-utils/src.Variable.run","hash":"exit"},"text":{},"parentId":1849},{"id":1863,"name":"forceRunAsync","kind":4096,"kindString":"Property","flags":{},"sources":[{"fileName":"packages/node-utils/src/process/run.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/node-utils/src/process/run.ts","line":374,"character":2,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/process/run.ts#L374"}],"type":{"type":"reflection","declaration":{"id":1864,"name":"forceRunAsync","kind":65536,"kindString":"Type literal","flags":{},"sources":[{"fileName":"packages/node-utils/src/process/run.ts","line":207,"character":16,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/process/run.ts#L207"}],"signatures":[{"id":1865,"name":"forceRunAsync","kind":4096,"kindString":"Call signature","flags":{},"comment":{"summary":[],"blockTags":[{"tag":"@function","content":[{"kind":"text","text":"forceRunAsync"}]},{"tag":"@description","content":[{"kind":"text","text":"在特定忽略模式下异步执行命令，带有错误抑制。Executes a command asynchronously with error suppression for graceful handling of optional operations."}]},{"tag":"@returns","content":[{"kind":"text","text":"解析为结果或void（如果错误被忽略）的Promise。Promise resolving to result or void if error is ignored"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Execute with graceful error handling\nawait forceRunAsync('optional-tool', ['--check']);\n// Will not throw if command fails, but logs error\n\n```"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Conditional command execution\ntry {\n  await forceRunAsync('git', ['status'], {\n    cwd: './maybe-git-repo'\n  });\n  console.log('Git repository detected');\n} catch (error) {\n  console.log('Not a git repository, continuing...');\n}\n\n```"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Build pipeline with optional steps\nawait forceRunAsync('npm', ['run', 'lint']);     // Optional linting\nawait forceRunAsync('npm', ['run', 'test']);     // Optional testing\nawait runAsync('npm', ['run', 'build']);         // Required build step\n\n```"}]},{"tag":"@since","content":[{"kind":"text","text":"1.0.0"}]},{"tag":"@see","content":[{"kind":"text","text":" - "},{"kind":"inline-tag","tag":"@link","text":"runAsync","target":2132},{"kind":"text","text":" - Standard async execution with error handling"},{"kind":"text","text":"\n"},{"kind":"text","text":" - "},{"kind":"inline-tag","tag":"@link","text":"IGNORE","target":2153},{"kind":"text","text":" - Special error message for ignored failures"},{"kind":"text","text":"\n"}]}]},"parameters":[{"id":1866,"name":"cmd","kind":32768,"kindString":"Parameter","flags":{},"comment":{"summary":[{"kind":"text","text":"要执行的命令或文件URL。Command to execute or file URL"}]},"type":{"type":"union","types":[{"type":"intrinsic","name":"string"},{"type":"reference","name":"URL","qualifiedName":"URL","package":"@types/node"}]},"text":{"comment":"<p>要执行的命令或文件URL。Command to execute or file URL</p>\n"}},{"id":1867,"name":"args","kind":32768,"kindString":"Parameter","flags":{"isOptional":true},"comment":{"summary":[{"kind":"text","text":"命令参数数组。Array of command arguments"}]},"type":{"type":"array","elementType":{"type":"intrinsic","name":"string"}},"defaultValue":"[]","text":{"comment":"<p>命令参数数组。Array of command arguments</p>\n"}},{"id":1868,"name":"options","kind":32768,"kindString":"Parameter","flags":{"isOptional":true},"comment":{"summary":[{"kind":"text","text":"执行选项。Execution options"}]},"type":{"type":"reference","id":2154,"name":"RunOptions"},"defaultValue":"{}","text":{"comment":"<p>执行选项。Execution options</p>\n"}}],"type":{"type":"reference","typeArguments":[{"type":"union","types":[{"type":"reference","id":2171,"name":"RunResult"},{"type":"intrinsic","name":"void"}]}],"name":"Promise","qualifiedName":"Promise","package":"typescript"},"is":{"declaration":false},"location":{"query":"node-utils/src.Variable.run","hash":"forceRunAsync.__type"},"text":{"comment":"<h5>Function:</h5><p>forceRunAsync</p>\n<h5>Description:</h5><p>在特定忽略模式下异步执行命令，带有错误抑制。Executes a command asynchronously with error suppression for graceful handling of optional operations.</p>\n<h5>Returns:</h5><p>解析为结果或void（如果错误被忽略）的Promise。Promise resolving to result or void if error is ignored</p>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Execute with graceful error handling</span>\n<span class=\"pl-k\">await</span> <span class=\"pl-en\">forceRunAsync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>optional-tool<span class=\"pl-pds\">'</span></span>, [<span class=\"pl-s\"><span class=\"pl-pds\">'</span>--check<span class=\"pl-pds\">'</span></span>]);\n<span class=\"pl-c\">// Will not throw if command fails, but logs error</span>\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Conditional command execution</span>\n<span class=\"pl-k\">try</span> {\n  <span class=\"pl-k\">await</span> <span class=\"pl-en\">forceRunAsync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>git<span class=\"pl-pds\">'</span></span>, [<span class=\"pl-s\"><span class=\"pl-pds\">'</span>status<span class=\"pl-pds\">'</span></span>], {\n    cwd: <span class=\"pl-s\"><span class=\"pl-pds\">'</span>./maybe-git-repo<span class=\"pl-pds\">'</span></span>\n  });\n  <span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>Git repository detected<span class=\"pl-pds\">'</span></span>);\n} <span class=\"pl-k\">catch</span> (<span class=\"pl-smi\">error</span>) {\n  <span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>Not a git repository, continuing...<span class=\"pl-pds\">'</span></span>);\n}\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Build pipeline with optional steps</span>\n<span class=\"pl-k\">await</span> <span class=\"pl-en\">forceRunAsync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>npm<span class=\"pl-pds\">'</span></span>, [<span class=\"pl-s\"><span class=\"pl-pds\">'</span>run<span class=\"pl-pds\">'</span></span>, <span class=\"pl-s\"><span class=\"pl-pds\">'</span>lint<span class=\"pl-pds\">'</span></span>]);     <span class=\"pl-c\">// Optional linting</span>\n<span class=\"pl-k\">await</span> <span class=\"pl-en\">forceRunAsync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>npm<span class=\"pl-pds\">'</span></span>, [<span class=\"pl-s\"><span class=\"pl-pds\">'</span>run<span class=\"pl-pds\">'</span></span>, <span class=\"pl-s\"><span class=\"pl-pds\">'</span>test<span class=\"pl-pds\">'</span></span>]);     <span class=\"pl-c\">// Optional testing</span>\n<span class=\"pl-k\">await</span> <span class=\"pl-en\">runAsync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>npm<span class=\"pl-pds\">'</span></span>, [<span class=\"pl-s\"><span class=\"pl-pds\">'</span>run<span class=\"pl-pds\">'</span></span>, <span class=\"pl-s\"><span class=\"pl-pds\">'</span>build<span class=\"pl-pds\">'</span></span>]);         <span class=\"pl-c\">// Required build step</span>\n</code></pre>\n<h5>Since:</h5><p>1.0.0</p>\n<h5>See:</h5><ul>\n<li><a href=\"2132\">runAsync</a> - Standard async execution with error handling</li>\n<li><a href=\"2153\">IGNORE</a> - Special error message for ignored failures</li>\n</ul>\n"},"sources":[{"fileName":"packages/node-utils/src/process/run.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/node-utils/src/process/run.ts","line":207,"character":0,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/process/run.ts#L207"}],"parentId":1849}],"location":{"query":"node-utils/src.Variable.run","hash":"forceRunAsync"}}},"is":{"declaration":true},"location":{"query":"node-utils/src.Variable.run","hash":"forceRunAsync"},"text":{},"parentId":1849},{"id":1851,"name":"runAsync","kind":4096,"kindString":"Property","flags":{},"sources":[{"fileName":"packages/node-utils/src/process/run.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/node-utils/src/process/run.ts","line":372,"character":2,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/process/run.ts#L372"}],"type":{"type":"reflection","declaration":{"id":1852,"name":"runAsync","kind":65536,"kindString":"Type literal","flags":{},"sources":[{"fileName":"packages/node-utils/src/process/run.ts","line":81,"character":16,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/process/run.ts#L81"}],"signatures":[{"id":1853,"name":"runAsync","kind":4096,"kindString":"Call signature","flags":{},"comment":{"summary":[],"blockTags":[{"tag":"@function","content":[{"kind":"text","text":"runAsync"}]},{"tag":"@description","content":[{"kind":"text","text":"异步执行命令，带有综合错误处理和输出捕获。Asynchronously executes a command with comprehensive error handling, timeout support, and flexible output capture options."}]},{"tag":"@returns","content":[{"kind":"text","text":"解析为执行结果的Promise，包含状态码、stdout、stderr和成功状态。Promise resolving to execution result with code, stdout, stderr, and success status"}]},{"tag":"@throws","content":[{"kind":"text","text":"如果命令失败且ignoreFailure为false，或者发生超时则拒绝。Rejects if command fails and ignoreFailure is false, or if timeout occurs"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Basic command execution\ntry {\n  const result = await runAsync('ls', ['-la']);\n  console.log('Directory listing:', result.stdout);\n} catch (error) {\n  console.error('Command failed:', error.message);\n}\n\n```"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Command with timeout and output capture\nconst result = await runAsync('npm', ['install'], {\n  timeout: 30000,        // 30 second timeout\n  captureStdout: true,   // Capture output\n  ignoreFailure: false,  // Throw on failure\n  cwd: './project'       // Working directory\n});\n\n```"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Capture output as lines\nconst result = await runAsync('git', ['log', '--oneline'], {\n  captureStdout: 'lines'\n});\nconsole.log(`Found ${result.stdout.length} commits`);\n\n```"}]},{"tag":"@since","content":[{"kind":"text","text":"1.0.0"}]},{"tag":"@see","content":[{"kind":"text","text":" - "},{"kind":"inline-tag","tag":"@link","text":"runSync","target":2146},{"kind":"text","text":" - Synchronous command execution"},{"kind":"text","text":"\n"},{"kind":"text","text":" - "},{"kind":"inline-tag","tag":"@link","text":"forceRunAsync","target":2137},{"kind":"text","text":" - Async execution with error suppression"},{"kind":"text","text":"\n"}]}]},"parameters":[{"id":1854,"name":"cmd","kind":32768,"kindString":"Parameter","flags":{},"comment":{"summary":[{"kind":"text","text":"要执行的命令或文件URL。Command to execute or file URL"}]},"type":{"type":"union","types":[{"type":"intrinsic","name":"string"},{"type":"reference","name":"URL","qualifiedName":"URL","package":"@types/node"}]},"text":{"comment":"<p>要执行的命令或文件URL。Command to execute or file URL</p>\n"}},{"id":1855,"name":"args","kind":32768,"kindString":"Parameter","flags":{"isOptional":true},"comment":{"summary":[{"kind":"text","text":"命令参数数组。Array of command arguments"}]},"type":{"type":"array","elementType":{"type":"intrinsic","name":"string"}},"defaultValue":"[]","text":{"comment":"<p>命令参数数组。Array of command arguments</p>\n"}},{"id":1856,"name":"options","kind":32768,"kindString":"Parameter","flags":{"isOptional":true},"comment":{"summary":[{"kind":"text","text":"执行选项，包括超时、输出捕获和失败处理。Execution options including timeout, output capture, and failure handling"}]},"type":{"type":"reference","id":2154,"name":"RunOptions"},"defaultValue":"{}","text":{"comment":"<p>执行选项，包括超时、输出捕获和失败处理。Execution options including timeout, output capture, and failure handling</p>\n"}}],"type":{"type":"reference","typeArguments":[{"type":"reference","id":2171,"name":"RunResult"}],"name":"Promise","qualifiedName":"Promise","package":"typescript"},"is":{"declaration":false},"location":{"query":"node-utils/src.Variable.run","hash":"runAsync.__type"},"text":{"comment":"<h5>Function:</h5><p>runAsync</p>\n<h5>Description:</h5><p>异步执行命令，带有综合错误处理和输出捕获。Asynchronously executes a command with comprehensive error handling, timeout support, and flexible output capture options.</p>\n<h5>Returns:</h5><p>解析为执行结果的Promise，包含状态码、stdout、stderr和成功状态。Promise resolving to execution result with code, stdout, stderr, and success status</p>\n<h5>Throws:</h5><p>如果命令失败且ignoreFailure为false，或者发生超时则拒绝。Rejects if command fails and ignoreFailure is false, or if timeout occurs</p>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Basic command execution</span>\n<span class=\"pl-k\">try</span> {\n  <span class=\"pl-k\">const</span> <span class=\"pl-c1\">result</span> <span class=\"pl-k\">=</span> <span class=\"pl-k\">await</span> <span class=\"pl-en\">runAsync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>ls<span class=\"pl-pds\">'</span></span>, [<span class=\"pl-s\"><span class=\"pl-pds\">'</span>-la<span class=\"pl-pds\">'</span></span>]);\n  <span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>Directory listing:<span class=\"pl-pds\">'</span></span>, <span class=\"pl-smi\">result</span>.<span class=\"pl-smi\">stdout</span>);\n} <span class=\"pl-k\">catch</span> (<span class=\"pl-smi\">error</span>) {\n  <span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">error</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>Command failed:<span class=\"pl-pds\">'</span></span>, <span class=\"pl-smi\">error</span>.<span class=\"pl-smi\">message</span>);\n}\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Command with timeout and output capture</span>\n<span class=\"pl-k\">const</span> <span class=\"pl-c1\">result</span> <span class=\"pl-k\">=</span> <span class=\"pl-k\">await</span> <span class=\"pl-en\">runAsync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>npm<span class=\"pl-pds\">'</span></span>, [<span class=\"pl-s\"><span class=\"pl-pds\">'</span>install<span class=\"pl-pds\">'</span></span>], {\n  timeout: <span class=\"pl-c1\">30000</span>,        <span class=\"pl-c\">// 30 second timeout</span>\n  captureStdout: <span class=\"pl-c1\">true</span>,   <span class=\"pl-c\">// Capture output</span>\n  ignoreFailure: <span class=\"pl-c1\">false</span>,  <span class=\"pl-c\">// Throw on failure</span>\n  cwd: <span class=\"pl-s\"><span class=\"pl-pds\">'</span>./project<span class=\"pl-pds\">'</span></span>       <span class=\"pl-c\">// Working directory</span>\n});\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Capture output as lines</span>\n<span class=\"pl-k\">const</span> <span class=\"pl-c1\">result</span> <span class=\"pl-k\">=</span> <span class=\"pl-k\">await</span> <span class=\"pl-en\">runAsync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>git<span class=\"pl-pds\">'</span></span>, [<span class=\"pl-s\"><span class=\"pl-pds\">'</span>log<span class=\"pl-pds\">'</span></span>, <span class=\"pl-s\"><span class=\"pl-pds\">'</span>--oneline<span class=\"pl-pds\">'</span></span>], {\n  captureStdout: <span class=\"pl-s\"><span class=\"pl-pds\">'</span>lines<span class=\"pl-pds\">'</span></span>\n});\n<span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">`</span>Found ${<span class=\"pl-smi\">result</span>.<span class=\"pl-smi\">stdout</span>.<span class=\"pl-c1\">length</span>} commits<span class=\"pl-pds\">`</span></span>);\n</code></pre>\n<h5>Since:</h5><p>1.0.0</p>\n<h5>See:</h5><ul>\n<li><a href=\"2146\">runSync</a> - Synchronous command execution</li>\n<li><a href=\"2137\">forceRunAsync</a> - Async execution with error suppression</li>\n</ul>\n"},"sources":[{"fileName":"packages/node-utils/src/process/run.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/node-utils/src/process/run.ts","line":81,"character":0,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/process/run.ts#L81"}],"parentId":1849}],"location":{"query":"node-utils/src.Variable.run","hash":"runAsync"}}},"is":{"declaration":true},"location":{"query":"node-utils/src.Variable.run","hash":"runAsync"},"text":{},"parentId":1849},{"id":1869,"name":"runPromise","kind":4096,"kindString":"Property","flags":{},"sources":[{"fileName":"packages/node-utils/src/process/run.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/node-utils/src/process/run.ts","line":375,"character":2,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/process/run.ts#L375"}],"type":{"type":"reflection","declaration":{"id":1870,"name":"runPromise","kind":65536,"kindString":"Type literal","flags":{},"sources":[{"fileName":"packages/node-utils/src/process/run.ts","line":250,"character":16,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/process/run.ts#L250"}],"signatures":[{"id":1871,"name":"runPromise","kind":4096,"kindString":"Call signature","flags":{},"comment":{"summary":[],"blockTags":[{"tag":"@function","content":[{"kind":"text","text":"runPromise"}]},{"tag":"@description","content":[{"kind":"text","text":"包装Promise并处理错误，在非忽略错误时退出进程。Wraps a promise with error handling that exits the process on non-ignored errors for critical operations."}]},{"tag":"@returns","content":[{"kind":"text","text":"在错误时退出进程或返回结果的Promise。Promise that exits process on error or returns result"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Critical operation that should exit on failure\nawait runPromise(\n  runAsync('npm', ['run', 'build'])\n);\n// Process will exit if build fails\n\n```"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Database migration that must succeed\nawait runPromise(\n  runAsync('npm', ['run', 'migrate'])\n);\nconsole.log('Migration completed successfully');\n\n```"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Chain critical operations\nawait runPromise(runAsync('git', ['pull']));\nawait runPromise(runAsync('npm', ['install']));\nawait runPromise(runAsync('npm', ['run', 'deploy']));\n\n```"}]},{"tag":"@since","content":[{"kind":"text","text":"1.0.0"}]},{"tag":"@see","content":[{"kind":"text","text":" - "},{"kind":"inline-tag","tag":"@link","text":"exit","target":2151},{"kind":"text","text":" - Process exit function"},{"kind":"text","text":"\n"},{"kind":"text","text":" - "},{"kind":"inline-tag","tag":"@link","text":"IGNORE","target":2153},{"kind":"text","text":" - Special error message for ignored failures"},{"kind":"text","text":"\n"}]}]},"typeParameter":[{"id":1872,"name":"T","kind":131072,"kindString":"Type parameter","flags":{}}],"parameters":[{"id":1873,"name":"promise","kind":32768,"kindString":"Parameter","flags":{},"comment":{"summary":[{"kind":"text","text":"要包装的带有错误处理的Promise。Promise to wrap with error handling"}]},"type":{"type":"reference","typeArguments":[{"type":"reference","id":1872,"name":"T"}],"name":"Promise","qualifiedName":"Promise","package":"typescript"},"text":{"comment":"<p>要包装的带有错误处理的Promise。Promise to wrap with error handling</p>\n"}}],"type":{"type":"reference","typeArguments":[{"type":"union","types":[{"type":"reference","id":1872,"name":"T"},{"type":"intrinsic","name":"void"}]}],"name":"Promise","qualifiedName":"Promise","package":"typescript"},"is":{"declaration":false},"location":{"query":"node-utils/src.Variable.run","hash":"runPromise.__type"},"text":{"comment":"<h5>Function:</h5><p>runPromise</p>\n<h5>Description:</h5><p>包装Promise并处理错误，在非忽略错误时退出进程。Wraps a promise with error handling that exits the process on non-ignored errors for critical operations.</p>\n<h5>Returns:</h5><p>在错误时退出进程或返回结果的Promise。Promise that exits process on error or returns result</p>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Critical operation that should exit on failure</span>\n<span class=\"pl-k\">await</span> <span class=\"pl-en\">runPromise</span>(\n  <span class=\"pl-en\">runAsync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>npm<span class=\"pl-pds\">'</span></span>, [<span class=\"pl-s\"><span class=\"pl-pds\">'</span>run<span class=\"pl-pds\">'</span></span>, <span class=\"pl-s\"><span class=\"pl-pds\">'</span>build<span class=\"pl-pds\">'</span></span>])\n);\n<span class=\"pl-c\">// Process will exit if build fails</span>\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Database migration that must succeed</span>\n<span class=\"pl-k\">await</span> <span class=\"pl-en\">runPromise</span>(\n  <span class=\"pl-en\">runAsync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>npm<span class=\"pl-pds\">'</span></span>, [<span class=\"pl-s\"><span class=\"pl-pds\">'</span>run<span class=\"pl-pds\">'</span></span>, <span class=\"pl-s\"><span class=\"pl-pds\">'</span>migrate<span class=\"pl-pds\">'</span></span>])\n);\n<span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>Migration completed successfully<span class=\"pl-pds\">'</span></span>);\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Chain critical operations</span>\n<span class=\"pl-k\">await</span> <span class=\"pl-en\">runPromise</span>(<span class=\"pl-en\">runAsync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>git<span class=\"pl-pds\">'</span></span>, [<span class=\"pl-s\"><span class=\"pl-pds\">'</span>pull<span class=\"pl-pds\">'</span></span>]));\n<span class=\"pl-k\">await</span> <span class=\"pl-en\">runPromise</span>(<span class=\"pl-en\">runAsync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>npm<span class=\"pl-pds\">'</span></span>, [<span class=\"pl-s\"><span class=\"pl-pds\">'</span>install<span class=\"pl-pds\">'</span></span>]));\n<span class=\"pl-k\">await</span> <span class=\"pl-en\">runPromise</span>(<span class=\"pl-en\">runAsync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>npm<span class=\"pl-pds\">'</span></span>, [<span class=\"pl-s\"><span class=\"pl-pds\">'</span>run<span class=\"pl-pds\">'</span></span>, <span class=\"pl-s\"><span class=\"pl-pds\">'</span>deploy<span class=\"pl-pds\">'</span></span>]));\n</code></pre>\n<h5>Since:</h5><p>1.0.0</p>\n<h5>See:</h5><ul>\n<li><a href=\"2151\">exit</a> - Process exit function</li>\n<li><a href=\"2153\">IGNORE</a> - Special error message for ignored failures</li>\n</ul>\n"},"sources":[{"fileName":"packages/node-utils/src/process/run.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/node-utils/src/process/run.ts","line":250,"character":0,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/process/run.ts#L250"}],"parentId":1849}],"location":{"query":"node-utils/src.Variable.run","hash":"runPromise"}}},"is":{"declaration":true},"location":{"query":"node-utils/src.Variable.run","hash":"runPromise"},"text":{},"parentId":1849},{"id":1857,"name":"runSync","kind":4096,"kindString":"Property","flags":{},"sources":[{"fileName":"packages/node-utils/src/process/run.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/node-utils/src/process/run.ts","line":373,"character":2,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/process/run.ts#L373"}],"type":{"type":"reflection","declaration":{"id":1858,"name":"runSync","kind":65536,"kindString":"Type literal","flags":{},"sources":[{"fileName":"packages/node-utils/src/process/run.ts","line":301,"character":16,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/process/run.ts#L301"}],"signatures":[{"id":1859,"name":"runSync","kind":4096,"kindString":"Call signature","flags":{},"comment":{"summary":[],"blockTags":[{"tag":"@function","content":[{"kind":"text","text":"runSync"}]},{"tag":"@description","content":[{"kind":"text","text":"同步执行命令并立即返回结果。Synchronously executes a command and returns the result immediately with comprehensive error handling."}]},{"tag":"@returns","content":[{"kind":"text","text":"包含状态码、stdout、stderr和成功状态的执行结果。Execution result with code, stdout, stderr, and success status"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Quick synchronous command\nconst result = runSync('git', ['rev-parse', 'HEAD']);\nif (result.success) {\n  console.log('Current commit:', result.stdout.trim());\n} else {\n  console.error('Failed to get commit hash:', result.stderr);\n}\n\n```"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Check tool availability\nconst dockerCheck = runSync('docker', ['--version']);\nif (dockerCheck.success) {\n  console.log('Docker is available');\n} else {\n  console.log('Docker not found, skipping containerization');\n}\n\n```"}]},{"tag":"@example","content":[{"kind":"code","text":"```ts\n// Environment setup validation\nconst nodeVersion = runSync('node', ['--version']);\nconst npmVersion = runSync('npm', ['--version']);\n\nconsole.log(`Node: ${nodeVersion.stdout.trim()}`);\nconsole.log(`NPM: ${npmVersion.stdout.trim()}`);\n\n```"}]},{"tag":"@since","content":[{"kind":"text","text":"1.0.0"}]},{"tag":"@see","content":[{"kind":"inline-tag","tag":"@link","text":"runAsync","target":2132},{"kind":"text","text":" - Asynchronous command execution"}]}]},"parameters":[{"id":1860,"name":"cmd","kind":32768,"kindString":"Parameter","flags":{},"comment":{"summary":[{"kind":"text","text":"要执行的命令或文件URL。Command to execute or file URL"}]},"type":{"type":"union","types":[{"type":"intrinsic","name":"string"},{"type":"reference","name":"URL","qualifiedName":"URL","package":"@types/node"}]},"text":{"comment":"<p>要执行的命令或文件URL。Command to execute or file URL</p>\n"}},{"id":1861,"name":"args","kind":32768,"kindString":"Parameter","flags":{"isOptional":true},"comment":{"summary":[{"kind":"text","text":"命令参数数组。Array of command arguments"}]},"type":{"type":"array","elementType":{"type":"intrinsic","name":"string"}},"defaultValue":"[]","text":{"comment":"<p>命令参数数组。Array of command arguments</p>\n"}},{"id":1862,"name":"options","kind":32768,"kindString":"Parameter","flags":{"isOptional":true},"comment":{"summary":[{"kind":"text","text":"同步执行选项。Synchronous execution options"}]},"type":{"type":"reference","name":"SpawnSyncOptions","qualifiedName":"SpawnSyncOptions","package":"@types/node"},"defaultValue":"{}","text":{"comment":"<p>同步执行选项。Synchronous execution options</p>\n"}}],"type":{"type":"reference","id":2171,"name":"RunResult"},"is":{"declaration":false},"location":{"query":"node-utils/src.Variable.run","hash":"runSync.__type"},"text":{"comment":"<h5>Function:</h5><p>runSync</p>\n<h5>Description:</h5><p>同步执行命令并立即返回结果。Synchronously executes a command and returns the result immediately with comprehensive error handling.</p>\n<h5>Returns:</h5><p>包含状态码、stdout、stderr和成功状态的执行结果。Execution result with code, stdout, stderr, and success status</p>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Quick synchronous command</span>\n<span class=\"pl-k\">const</span> <span class=\"pl-c1\">result</span> <span class=\"pl-k\">=</span> <span class=\"pl-en\">runSync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>git<span class=\"pl-pds\">'</span></span>, [<span class=\"pl-s\"><span class=\"pl-pds\">'</span>rev-parse<span class=\"pl-pds\">'</span></span>, <span class=\"pl-s\"><span class=\"pl-pds\">'</span>HEAD<span class=\"pl-pds\">'</span></span>]);\n<span class=\"pl-k\">if</span> (<span class=\"pl-smi\">result</span>.<span class=\"pl-smi\">success</span>) {\n  <span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>Current commit:<span class=\"pl-pds\">'</span></span>, <span class=\"pl-smi\">result</span>.<span class=\"pl-smi\">stdout</span>.<span class=\"pl-en\">trim</span>());\n} <span class=\"pl-k\">else</span> {\n  <span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">error</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>Failed to get commit hash:<span class=\"pl-pds\">'</span></span>, <span class=\"pl-smi\">result</span>.<span class=\"pl-smi\">stderr</span>);\n}\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Check tool availability</span>\n<span class=\"pl-k\">const</span> <span class=\"pl-c1\">dockerCheck</span> <span class=\"pl-k\">=</span> <span class=\"pl-en\">runSync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>docker<span class=\"pl-pds\">'</span></span>, [<span class=\"pl-s\"><span class=\"pl-pds\">'</span>--version<span class=\"pl-pds\">'</span></span>]);\n<span class=\"pl-k\">if</span> (<span class=\"pl-smi\">dockerCheck</span>.<span class=\"pl-smi\">success</span>) {\n  <span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>Docker is available<span class=\"pl-pds\">'</span></span>);\n} <span class=\"pl-k\">else</span> {\n  <span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>Docker not found, skipping containerization<span class=\"pl-pds\">'</span></span>);\n}\n</code></pre>\n<h5>Example:</h5><pre><code class=\"language-ts\"><span class=\"pl-c\">// Environment setup validation</span>\n<span class=\"pl-k\">const</span> <span class=\"pl-c1\">nodeVersion</span> <span class=\"pl-k\">=</span> <span class=\"pl-en\">runSync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>node<span class=\"pl-pds\">'</span></span>, [<span class=\"pl-s\"><span class=\"pl-pds\">'</span>--version<span class=\"pl-pds\">'</span></span>]);\n<span class=\"pl-k\">const</span> <span class=\"pl-c1\">npmVersion</span> <span class=\"pl-k\">=</span> <span class=\"pl-en\">runSync</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>npm<span class=\"pl-pds\">'</span></span>, [<span class=\"pl-s\"><span class=\"pl-pds\">'</span>--version<span class=\"pl-pds\">'</span></span>]);\n\n<span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">`</span>Node: ${<span class=\"pl-smi\">nodeVersion</span>.<span class=\"pl-smi\">stdout</span>.<span class=\"pl-en\">trim</span>()}<span class=\"pl-pds\">`</span></span>);\n<span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">`</span>NPM: ${<span class=\"pl-smi\">npmVersion</span>.<span class=\"pl-smi\">stdout</span>.<span class=\"pl-en\">trim</span>()}<span class=\"pl-pds\">`</span></span>);\n</code></pre>\n<h5>Since:</h5><p>1.0.0</p>\n<h5>See:</h5><p><a href=\"2132\">runAsync</a> - Asynchronous command execution</p>\n"},"sources":[{"fileName":"packages/node-utils/src/process/run.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/node-utils/src/process/run.ts","line":301,"character":0,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/process/run.ts#L301"}],"parentId":1849}],"location":{"query":"node-utils/src.Variable.run","hash":"runSync"}}},"is":{"declaration":true},"location":{"query":"node-utils/src.Variable.run","hash":"runSync"},"text":{},"parentId":1849}],"groups":[{"title":"Properties","children":[1877]},{"title":"Methods","children":[1874,1863,1851,1869,1857]}],"sources":[{"fileName":"packages/node-utils/src/process/run.ts","line":371,"character":15,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/process/run.ts#L371"}],"location":{"query":"node-utils/src.Variable.run","hash":""}}},"is":{"declaration":true},"location":{"query":"node-utils/src.Variable.run","hash":""},"text":{},"parentId":965}
