guage-ts\"><span class=\"pl-c\">// Performance-based throttling</span>\n<span class=\"pl-en\">cpuUsage</span>((<span class=\"pl-v\">usage</span>) <span class=\"pl-k\">=></span> {\n  <span class=\"pl-k\">if</span> (<span class=\"pl-smi\">usage</span> <span class=\"pl-k\">></span> <span class=\"pl-c1\">0.8</span>) {\n    <span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">'</span>Throttling operations due to high CPU usage<span class=\"pl-pds\">'</span></span>);\n    <span class=\"pl-c\">// Implement throttling logic</span>\n  }\n});\n</code></pre>\n<h5>Since:</h5><p>1.0.0</p>\n<h5>See:</h5><ul>\n<li><a href=\"2211\">getCPUUsage</a> - Base CPU monitoring function</li>\n<li><a href=\"2215\">cpuFree</a> - Get CPU free percentage</li>\n</ul>\n"},"sources":[{"fileName":"packages/node-utils/src/system/os.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/node-utils/src/system/os.ts","line":675,"character":0,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/node-utils/src/system/os.ts#L675"}],"parentId":2218}],"is":{"declaration":true},"location":{"query":"node-utils/src.Function.cpuUsage","hash":""},"text":{},"parentId":965}
