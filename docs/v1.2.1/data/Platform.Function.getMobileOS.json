-k\">></span> <span class=\"pl-c1\">0</span>) <span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">`</span>iOS version: ${<span class=\"pl-smi\">ios</span>}<span class=\"pl-pds\">`</span></span>);\n<span class=\"pl-k\">if</span> (<span class=\"pl-smi\">android</span> <span class=\"pl-k\">></span> <span class=\"pl-c1\">0</span>) <span class=\"pl-c1\">console</span>.<span class=\"pl-c1\">log</span>(<span class=\"pl-s\"><span class=\"pl-pds\">`</span>Android version: ${<span class=\"pl-smi\">android</span>}<span class=\"pl-pds\">`</span></span>);\n</code></pre>\n"},"sources":[{"fileName":"packages/web-utils/src/platform.ts","fullFileName":"/home/runner/work/fe-tools/fe-tools/utils/packages/web-utils/src/platform.ts","line":244,"character":0,"url":"https://github.com/MichealWayne/fe-tools/blob/3274750/utils/packages/web-utils/src/platform.ts#L244"}],"parentId":1339}],"is":{"declaration":true},"location":{"query":"Platform.Function.getMobileOS","hash":""},"text":{},"parentId":1326}
